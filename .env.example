# ============================================================
# Larisin AI Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control!
# ============================================================

# Azure OpenAI — Caption & Text (gpt-4o)
OPENAI_AZURE_API=your_openai_api_key_here
ENDPOINT_AZURE_OPENAI=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure OpenAI — Image Generation (gpt-image-1.5)
AZURE_OPENAI_IMAGE_API=your_image_api_key_here
ENDPOINT_AZURE_OPENAI_IMAGE=https://your-resource-name.cognitiveservices.azure.com/
AZURE_OPENAI_IMAGE_DEPLOYMENT_NAME=gpt-image-1.5
AZURE_OPENAI_API_IMAGE_VERSION=2025-04-01-preview

# Azure Cosmos DB
COSMOS_URI=https://your-cosmos-account.documents.azure.com:443/
COSMOS_KEY=your_cosmos_primary_key_here
DB_NAME=your-database-name
CONTAINER_NAME=your-container-name

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your_account;AccountKey=your_key;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=your-container-name
AZURE_STORAGE_CONTAINER_URL=https://your-storage-account.blob.core.windows.net/your-container-name

# CORS — comma-separated list of allowed frontend origins
# Example: https://your-app.netlify.app,https://your-app.vercel.app
# Use * to allow all origins (development only)
ALLOWED_ORIGINS=*
